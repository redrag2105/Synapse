  "version": "0.2.0",
  "configurations": [

    {
      "name": "Synapse",
      "request": "launch",
      "type": "dart",
      "toolArgs": ["--suppress-analytics --dart-define-from-file=.env"]
    },
    {
      "name": "Synapse (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "Synapse (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define-from-file=.env"]
    }
  ]
}